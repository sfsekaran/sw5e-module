<div class="sw5e-starship-shell sw5e-starship-weapons">
  <header class="sw5e-starship-page-header">
    <div>
      <span class="sw5e-starship-kicker">{{title}}</span>
      <h2>{{title}}</h2>
      <p>{{subtitle}}</p>
    </div>

    {{#if bridgeActions.length}}
      <section class="sw5e-starship-toolbar">
        {{#each bridgeActions}}
          <button
            type="button"
            class="sw5e-starship-action-button"
            data-sw5e-action="open-tab"
            data-tab="{{id}}"
          >
            {{label}}
          </button>
        {{/each}}
      </section>
    {{/if}}
  </header>

  <section class="sw5e-starship-weapons-grid">
    {{#each sections}}
      <article class="sw5e-starship-weapon-bank">
        <header class="sw5e-starship-section-header">
          <div class="sw5e-starship-section-copy">
            <span class="sw5e-starship-kicker">{{label}}</span>
            <h3>{{label}}</h3>
            <p>{{description}}</p>
          </div>

          <div class="sw5e-starship-section-tools">
            <span class="sw5e-starship-section-count">{{count}}</span>
            {{#if browsePack}}
              <button
                type="button"
                class="sw5e-starship-group-link sw5e-starship-group-link-secondary"
                data-sw5e-action="open-pack"
                data-pack="{{browsePack}}"
              >
                Browse Pack
              </button>
            {{/if}}
            {{#if supportsSheetNavigation}}
              <button
                type="button"
                class="sw5e-starship-group-link"
                data-sw5e-action="open-tab"
                data-tab="{{defaultTab}}"
              >
                Open Cargo
              </button>
            {{/if}}
          </div>
        </header>

        <div class="sw5e-starship-weapon-list">
          {{#each items}}
            <article class="sw5e-starship-weapon-row">
              <div class="sw5e-starship-weapon-main">
                {{#if img}}
                  <button
                    type="button"
                    class="sw5e-starship-weapon-fire"
                    data-sw5e-action="use-item"
                    data-item-id="{{id}}"
                    title="Fire weapon"
                    aria-label="Fire {{name}}"
                  >
                    <img class="sw5e-starship-item-image" src="{{img}}" alt="" />
                  </button>
                {{/if}}

                <div class="sw5e-starship-item-copy">
                  <button
                    type="button"
                    class="sw5e-starship-item-name-button"
                    data-sw5e-action="open-item"
                    data-item-id="{{id}}"
                  >
                    {{name}}
                  </button>
                  {{#if meta}}
                    <span class="sw5e-starship-item-meta">{{meta}}</span>
                  {{/if}}
                </div>
              </div>

              <div class="sw5e-starship-weapon-telemetry">
                {{#each telemetry}}
                  <div class="sw5e-starship-weapon-stat">
                    <span class="sw5e-starship-weapon-stat-label">{{label}}</span>
                    <strong class="sw5e-starship-weapon-stat-value">{{value}}</strong>
                  </div>
                {{/each}}
              </div>

              <div class="sw5e-starship-weapon-controls">
                {{#if tags.length}}
                  <div class="sw5e-starship-weapon-tags">
                    {{#each tags}}
                      <span class="sw5e-starship-weapon-tag">{{this}}</span>
                    {{/each}}
                  </div>
                {{/if}}

                <div class="sw5e-starship-item-actions">
                  {{#if ../supportsSheetNavigation}}
                    <button
                      type="button"
                      class="sw5e-starship-item-button sw5e-starship-item-button-secondary"
                      data-sw5e-action="focus-item"
                      data-item-id="{{id}}"
                      data-tab="{{defaultTab}}"
                    >
                      Locate
                    </button>
                  {{/if}}
                  <button
                    type="button"
                    class="sw5e-starship-item-button sw5e-starship-item-button-danger"
                    data-sw5e-action="delete-item"
                    data-item-id="{{id}}"
                  >
                    Remove
                  </button>
                </div>
              </div>
            </article>
          {{/each}}
        </div>
      </article>
    {{/each}}
  </section>
</div>
