<div class="sw5e-starship-panel">
  <header class="sw5e-starship-hero">
    {{#if actorImage}}
      <img class="sw5e-starship-hero-image" src="{{actorImage}}" alt="{{actorName}}" />
    {{/if}}

    <div class="sw5e-starship-hero-copy">
      <span class="sw5e-starship-kicker">{{title}}</span>
      <h2>{{actorName}}</h2>
      <p>{{subtitle}}</p>

      {{#if headerBadges.length}}
        <div class="sw5e-starship-badges">
          {{#each headerBadges}}
            <span class="sw5e-starship-badge">{{this}}</span>
          {{/each}}
        </div>
      {{/if}}
    </div>

    {{#if legacyNotes.length}}
      <div class="sw5e-starship-notes">
        {{#each legacyNotes}}
          <span class="sw5e-starship-note">{{this}}</span>
        {{/each}}
      </div>
    {{/if}}
  </header>

  {{#if overviewCards.length}}
    <section class="sw5e-starship-overview">
      {{#each overviewCards}}
        <article class="sw5e-starship-card">
          <span class="sw5e-starship-card-label">{{label}}</span>
          <strong class="sw5e-starship-card-value">{{value}}</strong>
          {{#if note}}
            <span class="sw5e-starship-card-note">{{note}}</span>
          {{/if}}
        </article>
      {{/each}}
    </section>
  {{/if}}

  {{#if crew}}
    <section class="sw5e-starship-crew-section">
      <header class="sw5e-starship-section-header sw5e-crew-section-header">
        <div>
          <span class="sw5e-starship-kicker">Crew &amp; Passengers</span>
          <h2>Crew Management</h2>
        </div>
        <button type="button" class="sw5e-starship-item-button" data-sw5e-crew-command="open-add-crew">+ Add Crew Member</button>
      </header>

      {{#if crew.roster.length}}
        <div class="sw5e-starship-item-list">
          {{#each crew.roster}}
            <article class="sw5e-starship-item-row{{#if active}} sw5e-crew-active{{/if}}">
              <div class="sw5e-starship-item-main">
                <img class="sw5e-starship-item-image" src="{{img}}" alt="{{name}}" />
                <div class="sw5e-starship-item-copy">
                  <strong class="sw5e-starship-item-name">{{name}}</strong>
                  <div class="sw5e-crew-badges">
                    {{#if isPilot}}<span class="sw5e-crew-badge sw5e-crew-badge-pilot">Pilot</span>{{/if}}
                    {{#if active}}<span class="sw5e-crew-badge sw5e-crew-badge-active">Active</span>{{/if}}
                    {{#unless isPilot}}{{#if isCrew}}<span class="sw5e-crew-badge">Crew</span>{{/if}}{{/unless}}
                    {{#if isPassenger}}<span class="sw5e-crew-badge">Passenger</span>{{/if}}
                  </div>
                </div>
              </div>
              <div class="sw5e-starship-item-actions">
                {{#if isPilot}}
                  <button type="button" class="sw5e-starship-item-button" data-sw5e-crew-command="undeploy-pilot" data-actor-uuid="{{uuid}}">Clear Pilot</button>
                {{else}}
                  <button type="button" class="sw5e-starship-item-button" data-sw5e-crew-command="set-pilot" data-actor-uuid="{{uuid}}">Set Pilot</button>
                {{/if}}
                <button type="button" class="sw5e-starship-item-button" data-sw5e-crew-command="toggle-active" data-actor-uuid="{{uuid}}">
                  {{#if active}}Deactivate{{else}}Activate{{/if}}
                </button>
                <button type="button" class="sw5e-starship-item-button sw5e-starship-item-button-danger" data-sw5e-crew-command="remove" data-actor-uuid="{{uuid}}">Remove</button>
              </div>
            </article>
          {{/each}}
        </div>
      {{else}}
        <p class="sw5e-crew-empty">No crew assigned. Use "+ Add Crew Member" to assign crew.</p>
      {{/if}}
    </section>
  {{/if}}

  {{#if skills.length}}
    <section class="sw5e-starship-skills">
      <header class="sw5e-starship-section-header">
        <div>
          <span class="sw5e-starship-kicker">Starship Skills</span>
          <h2>Skill Console</h2>
          <p>Vehicle-backed skill rolls now run through a dedicated ship skill path instead of the normal character skill workflow.</p>
        </div>
      </header>

      <div class="sw5e-starship-skill-grid">
        {{#each skills}}
          <article class="sw5e-starship-skill-row">
            <div class="sw5e-starship-skill-copy">
              <strong>{{label}}</strong>
              <span>{{abilityLabel}}{{#if hover}} | {{hover}}{{/if}}</span>
            </div>

            <div class="sw5e-starship-skill-total">{{total}}</div>

            <button
              type="button"
              class="sw5e-starship-item-button"
              data-sw5e-action="roll-skill"
              data-skill-id="{{id}}"
            >
              Roll
            </button>
          </article>
        {{/each}}
      </div>
    </section>
  {{/if}}

  <section class="sw5e-starship-groups">
    {{#each groups}}
      <article class="sw5e-starship-group">
        <header class="sw5e-starship-group-header">
          <div class="sw5e-starship-group-title">
            <h3>{{label}}</h3>
            <p>Browse here first, then use the row actions to open details and jump deeper into the stock sheet when available.</p>
          </div>
          <div class="sw5e-starship-group-tools">
            <span class="sw5e-starship-group-count">{{count}}</span>
            {{#if supportsSheetNavigation}}
              <button
                type="button"
                class="sw5e-starship-group-link"
                data-sw5e-action="open-tab"
                data-first-item-id="{{firstItemId}}"
              >
                Manage in {{manageLabel}}
              </button>
            {{/if}}
          </div>
        </header>

        <div class="sw5e-starship-item-list">
          {{#each items}}
            <article class="sw5e-starship-item-row">
              <div class="sw5e-starship-item-main">
                {{#if img}}
                  <button
                    type="button"
                    class="sw5e-starship-item-icon-button"
                    data-sw5e-action="use-item"
                    data-item-id="{{id}}"
                    title="Roll or post to chat"
                    aria-label="Roll or post {{name}} to chat"
                  >
                    <img class="sw5e-starship-item-image" src="{{img}}" alt="" />
                  </button>
                {{/if}}

                <div class="sw5e-starship-item-copy">
                  <strong class="sw5e-starship-item-name">{{name}}</strong>
                  {{#if meta}}
                    <span class="sw5e-starship-item-meta">{{meta}}</span>
                  {{/if}}
                </div>
              </div>

              <div class="sw5e-starship-item-actions">
                <button
                  type="button"
                  class="sw5e-starship-item-button"
                  data-sw5e-action="open-item"
                  data-item-id="{{id}}"
                >
                  Open
                </button>
                <button
                  type="button"
                  class="sw5e-starship-item-button sw5e-starship-item-button-danger"
                  data-sw5e-action="delete-item"
                  data-item-id="{{id}}"
                >
                  Delete
                </button>
                {{#if ../supportsSheetNavigation}}
                  <button
                    type="button"
                    class="sw5e-starship-item-button sw5e-starship-item-button-secondary"
                    data-sw5e-action="focus-item"
                    data-item-id="{{id}}"
                    data-tab="{{defaultTab}}"
                  >
                    Find in Sheet
                  </button>
                {{/if}}
              </div>
            </article>
          {{/each}}
        </div>
      </article>
    {{/each}}
  </section>
</div>
