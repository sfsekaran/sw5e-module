<div class="sw5e-starship-shell sw5e-starship-bridge">
  <header class="sw5e-starship-bridge-header">
    <div class="sw5e-starship-bridge-identity">
      {{#if actorImage}}
        <img class="sw5e-starship-bridge-image" src="{{actorImage}}" alt="{{actorName}}" />
      {{/if}}

      <div class="sw5e-starship-bridge-copy">
        <span class="sw5e-starship-kicker">{{title}}</span>
        <h2>{{actorName}}</h2>
        <p>{{subtitle}}</p>

        {{#if headerBadges.length}}
          <div class="sw5e-starship-badges">
            {{#each headerBadges}}
              <span class="sw5e-starship-badge">{{this}}</span>
            {{/each}}
          </div>
        {{/if}}
      </div>
    </div>

    <div class="sw5e-starship-bridge-side">
      {{#if bridgeActions.length}}
        <section class="sw5e-starship-toolbar">
          {{#each bridgeActions}}
            <button
              type="button"
              class="sw5e-starship-action-button"
              data-sw5e-action="open-tab"
              data-tab="{{id}}"
            >
              {{label}}
            </button>
          {{/each}}
        </section>
      {{/if}}

      {{#if legacyNotes.length}}
        <div class="sw5e-starship-notes">
          {{#each legacyNotes}}
            <span class="sw5e-starship-note">{{this}}</span>
          {{/each}}
        </div>
      {{/if}}
    </div>
  </header>

  <section class="sw5e-starship-summary-grid">
    {{#each summaryCards}}
      <article class="sw5e-starship-summary-card sw5e-starship-summary-card-{{tone}}">
        <span class="sw5e-starship-summary-label">{{label}}</span>
        <strong class="sw5e-starship-summary-value">{{value}}</strong>
        {{#if note}}
          <span class="sw5e-starship-summary-note">{{note}}</span>
        {{/if}}
      </article>
    {{/each}}
  </section>

  <section class="sw5e-starship-panel-grid">
    <article class="sw5e-starship-panel-card">
      <header class="sw5e-starship-panel-header">
        <span class="sw5e-starship-kicker">Status</span>
        <h3>Ship Profile</h3>
      </header>

      <div class="sw5e-starship-data-list">
        {{#each statusEntries}}
          <article class="sw5e-starship-data-item">
            <span class="sw5e-starship-data-label">{{label}}</span>
            <strong class="sw5e-starship-data-value">{{value}}</strong>
            {{#if note}}
              <span class="sw5e-starship-data-note">{{note}}</span>
            {{/if}}
          </article>
        {{/each}}
      </div>
    </article>

    <article class="sw5e-starship-panel-card">
      <header class="sw5e-starship-panel-header">
        <span class="sw5e-starship-kicker">Operations</span>
        <h3>Bridge Readout</h3>
      </header>

      <div class="sw5e-starship-data-list">
        {{#each logisticsEntries}}
          <article class="sw5e-starship-data-item">
            <span class="sw5e-starship-data-label">{{label}}</span>
            <strong class="sw5e-starship-data-value">{{value}}</strong>
            {{#if note}}
              <span class="sw5e-starship-data-note">{{note}}</span>
            {{/if}}
          </article>
        {{/each}}
      </div>
    </article>

    <article class="sw5e-starship-panel-card sw5e-starship-panel-card-wide">
      <header class="sw5e-starship-panel-header">
        <div class="sw5e-starship-section-copy">
          <span class="sw5e-starship-kicker">{{powerRouting.kicker}}</span>
          <h3>{{powerRouting.title}}</h3>
          <p>{{powerRouting.summary}}</p>
        </div>

        <div class="sw5e-starship-section-tools">
          <span class="sw5e-starship-section-count">{{powerRouting.totalValue}}</span>
          <span class="sw5e-starship-power-total-label">{{powerRouting.totalLabel}}</span>
          {{#if isEditable}}
            <button
              type="button"
              class="sw5e-starship-group-link sw5e-starship-group-link-secondary"
              data-sw5e-action="set-power-routing"
              data-routing="none"
            >
              {{powerRouting.clearLabel}}
            </button>
          {{/if}}
        </div>
      </header>

      <div class="sw5e-starship-routing-grid">
        {{#each powerRouting.routes}}
          <article class="sw5e-starship-routing-channel {{#if isPrimary}}is-primary{{/if}}">
            <div class="sw5e-starship-routing-copy">
              <span class="sw5e-starship-power-label">{{label}}</span>
              <strong class="sw5e-starship-routing-symbol">{{symbol}}</strong>
              <span class="sw5e-starship-routing-effect">{{effect}}</span>
            </div>

            <div class="sw5e-starship-routing-control">
              <input
                type="range"
                class="sw5e-starship-routing-slider"
                min="0"
                max="2"
                step="1"
                value="{{value}}"
                data-sw5e-power-route="{{key}}"
                aria-label="{{label}}"
                {{#unless ../isEditable}}disabled{{/unless}}
              >
            </div>
          </article>
        {{/each}}
      </div>

      <section class="sw5e-starship-power-allocation">
        <header class="sw5e-starship-section-header">
          <div class="sw5e-starship-section-copy">
            <span class="sw5e-starship-kicker">{{powerRouting.allocationLabel}}</span>
            <h3>{{powerRouting.allocationLabel}}</h3>
            <p>Stored power by station and subsystem.</p>
          </div>
        </header>

        <div class="sw5e-starship-power-grid">
          {{#each powerRouting.slots}}
            <article class="sw5e-starship-power-cell {{#if isPrimary}}is-primary{{/if}}">
              <span class="sw5e-starship-power-label">{{label}}</span>
              {{#if ../isEditable}}
                <input
                  type="number"
                  class="sw5e-starship-power-input"
                  min="0"
                  step="1"
                  value="{{value}}"
                  data-sw5e-power-slot="{{key}}"
                  aria-label="{{label}}"
                >
              {{else}}
                <strong class="sw5e-starship-power-value">{{value}}</strong>
              {{/if}}
            </article>
          {{/each}}
        </div>
      </section>
    </article>
  </section>

  {{#if quickGroups.length}}
    <section class="sw5e-starship-quick-grid">
      {{#each quickGroups}}
        <article class="sw5e-starship-section-card">
          <header class="sw5e-starship-section-header">
            <div class="sw5e-starship-section-copy">
              <span class="sw5e-starship-kicker">{{label}}</span>
              <h3>{{label}}</h3>
              <p>{{description}}</p>
            </div>
            <div class="sw5e-starship-section-tools">
              <span class="sw5e-starship-section-count">{{count}}</span>
              {{#if browsePack}}
                <button
                  type="button"
                  class="sw5e-starship-group-link sw5e-starship-group-link-secondary"
                  data-sw5e-action="open-pack"
                  data-pack="{{browsePack}}"
                >
                  Browse Pack
                </button>
              {{/if}}
              {{#if supportsSheetNavigation}}
                <button
                  type="button"
                  class="sw5e-starship-group-link"
                  data-sw5e-action="open-tab"
                  data-tab="{{defaultTab}}"
                >
                  Open {{manageLabel}}
                </button>
              {{/if}}
            </div>
          </header>

          <div class="sw5e-starship-item-list">
            {{#each items}}
              <article class="sw5e-starship-item-row">
                <div class="sw5e-starship-item-main">
                  {{#if img}}
                    <button
                      type="button"
                      class="sw5e-starship-item-icon-button"
                      data-sw5e-action="use-item"
                      data-item-id="{{id}}"
                      title="Roll or post to chat"
                      aria-label="Roll or post {{name}} to chat"
                    >
                      <img class="sw5e-starship-item-image" src="{{img}}" alt="" />
                    </button>
                  {{/if}}

                  <div class="sw5e-starship-item-copy">
                    <button
                      type="button"
                      class="sw5e-starship-item-name-button"
                      data-sw5e-action="open-item"
                      data-item-id="{{id}}"
                    >
                      {{name}}
                    </button>
                    {{#if meta}}
                      <span class="sw5e-starship-item-meta">{{meta}}</span>
                    {{/if}}
                  </div>
                </div>

                <div class="sw5e-starship-item-actions">
                  {{#if ../supportsSheetNavigation}}
                    <button
                      type="button"
                      class="sw5e-starship-item-button sw5e-starship-item-button-secondary"
                      data-sw5e-action="focus-item"
                      data-item-id="{{id}}"
                      data-tab="{{defaultTab}}"
                    >
                      Locate
                    </button>
                  {{/if}}
                </div>
              </article>
            {{/each}}
          </div>

          {{#if hasMore}}
            <footer class="sw5e-starship-section-footer">
              <span>{{remainingCount}} more in {{label}}</span>
            </footer>
          {{/if}}
        </article>
      {{/each}}
    </section>
  {{/if}}
</div>
