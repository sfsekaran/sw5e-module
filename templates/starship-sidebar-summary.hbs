<div class="sw5e-starship-sidebar-summary-inner">
  <header class="sw5e-starship-sidebar-summary-header">
    <span class="sw5e-starship-sidebar-summary-kicker">Starship Profile</span>
  </header>

  <div class="sw5e-starship-sidebar-summary-list">
    {{#each entries}}
      <article class="sw5e-starship-sidebar-summary-entry">
        <span class="sw5e-starship-sidebar-summary-label">{{label}}</span>
        <strong class="sw5e-starship-sidebar-summary-value">{{value}}</strong>
        {{#if note}}
          <span class="sw5e-starship-sidebar-summary-note">{{note}}</span>
        {{/if}}
      </article>
    {{/each}}
  </div>
</div>
