<section class="tab active sw5e-starship-tab" data-tab="sw5e-starship" data-group="primary">
  <div class="sw5e-starship-summary">
    <div class="sw5e-starship-identity">
      <img class="profile" src="{{actor.img}}" alt="{{actor.name}}">
      <div class="identity-copy">
        <h2>{{actor.name}}</h2>
        <p>{{classification.name}}</p>
        <p>{{classification.size}}{{#if classification.identifier}} | {{classification.identifier}}{{/if}}</p>
        <p>Tier {{classification.tier}}{{#if source}} | {{source}}{{/if}}</p>
      </div>
    </div>
    <div class="sw5e-starship-cards">
      <article class="sw5e-starship-card">
        <h3>Hull</h3>
        <strong>{{summary.hull.value}} / {{summary.hull.max}}</strong>
        {{#if summary.hull.die}}<span>{{summary.hull.die}}</span>{{/if}}
      </article>
      <article class="sw5e-starship-card">
        <h3>Shields</h3>
        <strong>{{summary.shields.value}} / {{summary.shields.max}}</strong>
        {{#if summary.shields.die}}<span>{{summary.shields.die}}</span>{{/if}}
      </article>
      <article class="sw5e-starship-card">
        <h3>Fuel</h3>
        <strong>{{summary.fuel.value}} / {{summary.fuel.cap}}</strong>
        <span>capacity</span>
      </article>
      <article class="sw5e-starship-card">
        <h3>Crew</h3>
        <strong>{{summary.deployment.crewCount}}</strong>
        <span>{{#if summary.deployment.pilotAssigned}}pilot assigned{{else}}no pilot assigned{{/if}}</span>
      </article>
      <article class="sw5e-starship-card">
        <h3>Passengers</h3>
        <strong>{{summary.deployment.passengerCount}}</strong>
        <span>on manifest</span>
      </article>
      <article class="sw5e-starship-card">
        <h3>System Damage</h3>
        <strong>{{summary.systemDamage}}</strong>
        <span>stored</span>
      </article>
    </div>
  </div>

  <div class="sw5e-starship-layout">
    <section class="sw5e-starship-panel">
      <header>
        <h3>Power Routing</h3>
        <span>{{summary.power.routing}}</span>
      </header>
      <div class="sw5e-starship-pill-grid">
        {{#each summary.power.allocations as |allocation|}}
        <div class="sw5e-starship-pill">
          <span>{{allocation.label}}</span>
          <strong>{{allocation.value}}</strong>
        </div>
        {{/each}}
      </div>
    </section>

    <section class="sw5e-starship-panel">
      <header>
        <h3>Starship Skills</h3>
        <span>{{skills.length}} listed</span>
      </header>
      <div class="sw5e-starship-skills">
        {{#each skills as |skill|}}
        <article class="sw5e-starship-skill">
          <div>
            <strong>{{skill.label}}</strong>
            <span>{{skill.abilityLabel}}</span>
          </div>
          <div class="skill-meta">
            <span>Prof {{skill.proficiency}}</span>
            <strong>{{numberFormat skill.total sign=true}}</strong>
          </div>
        </article>
        {{/each}}
      </div>
    </section>
  </div>

  <section class="sw5e-starship-groups">
    {{#each itemGroups as |group|}}
    <article class="sw5e-starship-panel">
      <header>
        <h3>{{group.label}}</h3>
        <span>{{group.items.length}} items</span>
      </header>
      <div class="sw5e-starship-items">
        {{#each group.items as |item|}}
        <button type="button" class="sw5e-starship-item" data-sw5e-open-item="true" data-item-id="{{item.id}}">
          <img src="{{item.img}}" alt="{{item.name}}">
          <span class="item-name">{{item.name}}</span>
          <span class="item-type">{{item.typeLabel}}</span>
        </button>
        {{/each}}
      </div>
    </article>
    {{/each}}
  </section>
</section>
