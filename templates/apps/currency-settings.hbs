<form class="flexcol sw5e-currency-settings-form">
    <section class="flexcol sw5e-currency-settings-body">
        <p class="hint">{{introHint}}</p>

        <div class="sw5e-currency-settings-grid">
            {{#each currencies}}
            <fieldset class="card sw5e-currency-card {{#if referenceOnly}}reference-only{{/if}}">
                <legend>{{labelText}}</legend>

                <div class="form-group">
                    <label>{{../enabledLabel}}</label>
                    <div class="form-fields">
                        <input type="checkbox" name="enabled.{{key}}" {{#if enabled}}checked{{/if}} {{#if isBaseCurrency}}disabled{{/if}}>
                    </div>
                </div>

                <div class="form-group">
                    <label>{{../abbreviationLabel}}</label>
                    <div class="form-fields">
                        <input type="text" value="{{abbreviationText}}" disabled>
                    </div>
                </div>

                <div class="form-group">
                    <label>{{../exchangeRateLabel}}</label>
                    <div class="form-fields">
                        {{#if fixed}}
                        <input type="text" value="{{fixedRateText}}" disabled>
                        {{else}}
                        <input type="text" name="customRate.{{key}}" inputmode="decimal"
                            placeholder="{{../customRatePlaceholder}}" value="{{customRateValue}}">
                        {{/if}}
                    </div>
                </div>

                {{#if isBaseCurrency}}
                <p class="hint">{{../baseCurrencyHint}}</p>
                {{/if}}

                <p class="hint">{{tooltip}}</p>

                {{#if referenceOnly}}
                <p class="hint">{{../referenceOnlyHint}}</p>
                {{/if}}
            </fieldset>
            {{/each}}
        </div>

    </section>

    <footer class="form-footer">
        <button type="submit" class="dialog-button default">
            <i class="fas fa-save" inert></i>
            <span>{{saveLabel}}</span>
        </button>
    </footer>
</form>
