<form class="sw5e-world-conversion-form flexcol">
  <p>
    Paste exported legacy SW5E world JSON data below, then run a dry run first. This tool is intended to run in a
    <strong>dnd5e</strong> world with <strong>sw5e-module</strong> enabled.
  </p>

  <div class="form-group">
    <label for="sw5e-world-conversion-payload">Legacy World JSON Payload</label>
    <textarea
      id="sw5e-world-conversion-payload"
      name="payload"
      rows="20"
      spellcheck="false"
      style="font-family: monospace;"
    >{{payloadExample}}</textarea>
  </div>

  <div class="form-group">
    <label>
      <input type="checkbox" name="options.replaceExisting" checked />
      Replace existing world documents when matching by _id
    </label>
  </div>

  <div class="form-group">
    <label>
      <input type="checkbox" name="options.includeCompendia" />
      Include compendium entries from payload.compendia
    </label>
  </div>

  <div class="form-group">
    <label>
      <input type="checkbox" name="options.dryRun" checked />
      Dry run (analyze only, do not write documents)
    </label>
  </div>

  <div class="form-group">
    <button type="submit">Run Conversion</button>
  </div>
</form>
