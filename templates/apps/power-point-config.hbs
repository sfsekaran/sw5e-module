<form class="flexcol sw5e-power-point-config-form">
    <section class="flexcol">
        <div class="final-value">{{value}} / {{effectiveMax}}</div>

        <fieldset class="card">
            <legend>{{maximumLegend}}</legend>

            <div class="form-group">
                <label>{{maxOverrideLabel}}</label>
                <div class="form-fields">
                    <input type="text" name="system.powercasting.{{castType}}.points.max" data-dtype="Number"
                        inputmode="numeric" pattern="^[+=\-]?\d*" placeholder="{{calculatedMax}}"
                        value="{{#if hasMaxOverride}}{{source.max}}{{/if}}">
                </div>
                <p class="hint">{{maxOverrideHint}}</p>
            </div>

            <div class="form-group">
                <label>{{perLevelBonusLabel}}</label>
                <div class="form-fields">
                    <input type="text" name="system.powercasting.{{castType}}.points.bonuses.level"
                        value="{{source.bonuses.level}}">
                </div>
            </div>

            <div class="form-group">
                <label>{{overallBonusLabel}}</label>
                <div class="form-fields">
                    <input type="text" name="system.powercasting.{{castType}}.points.bonuses.overall"
                        value="{{source.bonuses.overall}}">
                </div>
            </div>

            <div class="form-group">
                <label>{{tempMaxLabel}}</label>
                <div class="form-fields">
                    <input type="text" name="system.powercasting.{{castType}}.points.tempmax" data-dtype="Number"
                        inputmode="numeric" pattern="^[+=\-]?\d*" placeholder="0" value="{{source.tempmax}}">
                </div>
            </div>
        </fieldset>

        <fieldset class="card">
            <legend>{{currentLegend}}</legend>

            <div class="form-group">
                <label>{{currentLabel}}</label>
                <div class="form-fields">
                    <input type="text" name="system.powercasting.{{castType}}.points.value" data-dtype="Number"
                        inputmode="numeric" pattern="^[+=\-]?\d*" placeholder="0" value="{{source.value}}">
                </div>
            </div>

            <div class="form-group">
                <label>{{tempLabel}}</label>
                <div class="form-fields">
                    <input type="text" name="system.powercasting.{{castType}}.points.temp" data-dtype="Number"
                        inputmode="numeric" pattern="^[+=\-]?\d*" placeholder="0" value="{{source.temp}}">
                </div>
            </div>
        </fieldset>

        <footer class="form-footer">
            <button type="submit" class="dialog-button default">
                <i class="fas fa-save" inert></i>
                <span>{{saveLabel}}</span>
            </button>
        </footer>
    </section>
</form>
